   "metadata": {},
   "outputs": [],
   "source": [
    "np.random.seed(42)\n",
    "\n",
    "N = 600\n",
    "categories   = [\"Retail\", \"Travel\", \"Online\", \"ATM Withdrawal\", \"Wire Transfer\"]\n",
    "merchants    = [\"Amazon\", \"Delta Airlines\", \"Walmart\", \"Chase ATM\",\n",
    "                \"PayPal\", \"Best Buy\", \"Unknown Vendor\", \"Overseas Bank\"]\n",
    "user_ids     = [f\"U{str(i).zfill(4)}\" for i in range(1, 41)]\n",
    "\n",
    "dates = pd.date_range(\"2024-01-01\", periods=N, freq=\"12h\") + pd.to_timedelta(\n",
    "    np.random.randint(0, 43200, N), unit=\"s\"\n",
    ")\n",
    "\n",
    "amounts = np.concatenate([\n",
    "    np.random.lognormal(mean=4.5, sigma=0.8, size=int(N * 0.92)),   # normal txns\n",
    "    np.random.uniform(8000, 25000, size=int(N * 0.08)),              # fraud spikes\n",
    "])\n",
    "np.random.shuffle(amounts)\n",
    "amounts = np.round(amounts, 2)\n",
    "\n",
    "df = pd.DataFrame({\n",
    "    \"transaction_id\": [f\"TXN{str(i).zfill(5)}\" for i in range(1, N + 1)],\n",
    "    \"user_id\":        np.random.choice(user_ids, N),\n",
    "    \"timestamp\":      dates,\n",
    "    \"amount\":         amounts,\n",
    "    \"category\":       np.random.choice(categories, N, p=[0.35, 0.15, 0.30, 0.10, 0.10]),\n",
    "    \"merchant\":       np.random.choice(merchants, N),\n",
    "    \"country\":        np.random.choice([\"IN\", \"US\", \"UK\", \"NG\", \"RU\", \"CN\"],\n",
    "                                       N, p=[0.50, 0.20, 0.10, 0.07, 0.07, 0.06]),\n",
    "    \"hour\":           [d.hour for d in dates],\n",
    "})\n",
    "df[\"date\"] = df[\"timestamp\"].dt.date"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "8203a618-ad65-42b2-862a-b51129524db3",
   "metadata": {},
   "outputs": [],
   "source": [
    "conn = sqlite3.connect(\":memory:\")\n",
    "df.to_sql(\"transactions\", conn, index=False, if_exists=\"replace\")\n",
    "\n",
    "query = \"\"\"\n",
    "SELECT\n",
    "    transaction_id, user_id, timestamp, amount, category,\n",
    "    merchant, country, hour, date,\n",
    "    SUM(amount) OVER (PARTITION BY user_id ORDER BY timestamp\n",
    "        ROWS BETWEEN 9 PRECEDING AND CURRENT ROW)  AS rolling_user_10,\n",
    "    AVG(amount) OVER (PARTITION BY category)       AS avg_cat_amount,\n",
    "    COUNT(*)    OVER (PARTITION BY user_id,  date) AS daily_txn_count\n",
    "FROM transactions\n",
    "ORDER BY timestamp\n",
    "\"\"\"\n",
    "data = pd.read_sql(query, conn)\n",
    "conn.close()\n",
    "\n",
    "data[\"timestamp\"] = pd.to_datetime(data[\"timestamp\"])\n",
    "data[\"date\"]      = pd.to_datetime(data[\"date\"])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 33,
   "id": "cc39b398-10a2-4b09-92ea-b966b3665cd4",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "  Z-Score Flagged     : 30  (5.0%)\n"
     ]
    }
   ],
   "source": [
    "data[\"zscore\"] = (data[\"amount\"] - data[\"amount\"].mean()) / data[\"amount\"].std()\n",
    "data[\"flag_zscore\"] = data[\"zscore\"].abs() > 2.8\n",
    "\n",
    "print(f\"  Z-Score Flagged     : {data['flag_zscore'].sum():,}  ({data['flag_zscore'].mean()*100:.1f}%)\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "f7810bf6-1d09-4e38-b765-ae3d40c7b323",
   "metadata": {},
   "outputs": [],
   "source": [
    "Q1, Q3 = data[\"amount\"].quantile(0.25), data[\"amount\"].quantile(0.75)\n",
    "IQR     = Q3 - Q1\n",
    "lower, upper = Q1 - 1.5 * IQR, Q3 + 1.5 * IQR\n",
    "data[\"flag_iqr\"] = (data[\"amount\"] < lower) | (data[\"amount\"] > upper)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "bdfe3024-cf93-46c8-a25b-cb75746c1421",
   "metadata": {},
   "outputs": [],
   "source": [
    "data[\"flag_velocity\"] = data[\"daily_txn_count\"] > 4"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "bd338d8c-0436-4ad6-8ff4-1b0a416d01e3",
   "metadata": {},
   "outputs": [],
   "source": [
    "data[\"flag_country\"] = data[\"country\"].isin([\"NG\", \"RU\", \"CN\"])"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "ae126192-dd5b-4efc-a481-96541dbe148b",
   "metadata": {},
   "outputs": [],
   "source": [
    "data[\"risk_score\"] = (\n",
    "    data[\"flag_zscore\"].astype(int)   * 35 +\n",
    "    data[\"flag_iqr\"].astype(int)      * 25 +\n",
    "    data[\"flag_velocity\"].astype(int) * 20 +\n",
    "    data[\"flag_country\"].astype(int)  * 20\n",
    ")\n",
    "data[\"risk_level\"] = pd.cut(\n",
    "    data[\"risk_score\"],\n",
    "    bins=[-1, 0, 34, 59, 100],\n",
    "    labels=[\"Low\", \"Medium\", \"High\", \"Critical\"]\n",
    ")\n",
    "anomalies = data[data[\"risk_score\"] > 0].copy()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "be32cd16-c723-447c-99d0-854ef067ecb9",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "weekly = (\n",
    "    data.set_index(\"timestamp\")\n",
    "        .resample(\"W\")[\"amount\"]\n",
    "        .agg([\"sum\", \"count\", \"mean\"])\n",
    "        .reset_index()\n",
    ")\n",
    "weekly.columns = [\"week\", \"total\", \"count\", \"avg\"]\n",
    "\n",
    "risk_by_cat  = data.groupby(\"category\")[\"risk_score\"].mean().sort_values(ascending=False)\n",
    "flags_daily  = (\n",
    "    data.set_index(\"timestamp\")\n",
    "        .resample(\"W\")[[\"flag_zscore\",\"flag_iqr\",\"flag_velocity\"]]\n",
    "        .sum()\n",
    "        .reset_index()\n",
    ")\n",
    "top_users = (\n",
    "    anomalies.groupby(\"user_id\")[\"risk_score\"]\n",
    "    .sum().nlargest(8).reset_index()\n",
    ")\n",
    "risk_dist  = data[\"risk_level\"].value_counts().reindex([\"Low\",\"Medium\",\"High\",\"Critical\"])\n",
    "hour_risk  = data.groupby(\"hour\")[\"risk_score\"].mean()\n",
    "country_vol = anomalies[\"country\"].value_counts()"
   ]
  },
